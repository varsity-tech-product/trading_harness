    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist/",
    "bin/"
  ],
  "keywords": [
    "mcp",
    "arena",
    "trading",
    "varsity",
    "claude",
    "gemini",
    "openclaw",
    "codex",
    "agent",
    "tui"
