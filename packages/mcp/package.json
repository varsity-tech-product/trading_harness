{
  "name": "@varsity-arena/agent",
  "version": "0.4.0",
  "description": "Full-platform Arena agent toolkit — 49 MCP tools, web dashboard, CLI for competitions/trading/leaderboards",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/varsity-tech-product/arena.git",
    "directory": "packages/mcp"
  },
  "homepage": "https://github.com/varsity-tech-product/arena/tree/main/packages/mcp",
  "bugs": {
    "url": "https://github.com/varsity-tech-product/arena/issues"
  },
  "type": "module",
  "bin": {
    "arena-mcp": "./dist/cli.js",
    "arena-agent": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc && mkdir -p dist/dashboard && cp src/dashboard/index.html dist/dashboard/",
    "prepare": "npm run build",
    "prepack": "npm run build",
    "dev": "tsc --watch",
    "serve": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "yaml": "^2.8.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/",
    "bin/"
  ],
  "keywords": [
    "mcp",
    "arena",
    "trading",
    "varsity",
    "claude",
    "gemini",
    "openclaw",
    "codex",
    "agent",
    "tui"
  ],
  "license": "MIT"
}
