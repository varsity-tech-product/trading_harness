{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "action": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "OPEN_LONG",
            "OPEN_SHORT",
            "CLOSE_POSITION",
            "UPDATE_TPSL",
            "HOLD"
          ]
        },
        "size": {
          "type": [
            "number",
            "null"
          ]
        },
        "take_profit": {
          "type": [
            "number",
            "null"
          ]
        },
        "stop_loss": {
          "type": [
            "number",
            "null"
          ]
        },
        "confidence": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "strategy": {
          "description": "Optional per-action strategy overrides. Set to \"none\" to bypass the strategy layer. Or provide an object with sizing/tpsl/exit_rules overrides.",
          "type": [
            "object",
            "string",
            "null"
          ]
        },
        "indicators": {
          "description": "Optional list of indicator specs to add for the next tick. Example: [{\"indicator\": \"SMA\", \"params\": {\"period\": 200}}]",
          "type": [
            "array",
            "null"
          ]
        }
      },
      "required": [
        "type",
        "size",
        "take_profit",
        "stop_loss",
        "confidence",
        "reason"
      ]
    }
  },
  "required": [
    "action"
  ]
}
